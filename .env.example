# Copy this file to `.env.local` and fill in real values.
# Next.js loads `.env.local` automatically (never commit it).

# PostgreSQL — use Neon (free), Supabase, Railway, or local Docker. Everyone who opens your
# deployed app must use the SAME URL (set it in Vercel → Environment Variables too).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/DBNAME?sslmode=require"

# Google OAuth (Sheets import) — from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: public URL for OAuth redirect (must match Authorized redirect URI host)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin-only Google Sheets import (/admin/import). Set a strong password; never commit real values.
ADMIN_IMPORT_USER=admin
ADMIN_IMPORT_PASSWORD=choose-a-strong-password

# Optional: extra secret for signing the admin session cookie (defaults to a derivation of ADMIN_IMPORT_PASSWORD)
# ADMIN_IMPORT_SECRET=long-random-string

# Optional: one-time reset via API — POST /api/admin/seed with header x-seed-secret (then remove)
# SEED_SECRET=generate-a-long-random-string
