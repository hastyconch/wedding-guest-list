# Copy this file to `.env.local` and fill in real values.
# Next.js loads `.env.local` automatically (never commit it).

DATABASE_URL="file:./dev.db"

# Google OAuth (Sheets import) — from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: public URL for OAuth redirect (must match Authorized redirect URI host)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
